@page
@model BlindMatchPAS.Pages.StudentsModel
@{
    ViewData["Title"] = "Student Management";
}

<style>
    .card-box {
        background: white;
        border-radius: 15px;
        padding: 30px;
        border: 1px solid #eef2f6;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .table thead th {
        background-color: #f8f9fa;
        color: #6c757d;
        font-size: 0.85rem;
        text-transform: uppercase;
        border-bottom: 2px solid #dee2e6;
    }
</style>

<div class="container-fluid p-4">
    <div class="card-box">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0">👤 Student Management</h3>
            <button class="btn btn-primary fw-bold" style="border-radius: 8px;" data-bs-toggle="modal" data-bs-target="#studentModal">
                + Add New Student
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Research Interest</th>
                        <th>GPA</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in StudentsModel.StudentList)
                    {
                        <tr>
                            <td class="ps-3">@student.Id</td>
                            <td class="fw-bold">@student.Name</td>
                            <td>@student.Email</td>
                            <td><span class="badge bg-secondary opacity-75">@student.Interest</span></td>
                            <td class="fw-bold">@student.GPA</td>
                            <td class="text-end pe-3">
                                <button class="btn btn-sm btn-outline-dark me-1"
                                        onclick="fillEditModal('@student.Id', '@student.Name', '@student.Email', '@student.Interest', '@student.GPA')">
                                    Edit
                                </button>
                                <form method="post" asp-page-handler="Remove" asp-route-id="@student.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove student @student.Name?')">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="studentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 12px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold" id="modalTitle">Add New Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="SaveStudent">
                <div class="modal-body p-4">
                    <input type="hidden" asp-for="CurrentStudent.Id" id="studentId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Full Name</label>
                        <input type="text" asp-for="CurrentStudent.Name" class="form-control" id="studentName" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Email</label>
                        <input type="email" asp-for="CurrentStudent.Email" class="form-control" id="studentEmail" required>
                    </div>
                    <div class="row">
                        <div class="col-8 mb-3">
                            <label class="form-label small fw-bold">Research Interest</label>
                            <input type="text" asp-for="CurrentStudent.Interest" class="form-control" id="studentInterest" required>
                        </div>
                        <div class="col-4 mb-3">
                            <label class="form-label small fw-bold">GPA</label>
                            <input type="number" step="0.01" asp-for="CurrentStudent.GPA" class="form-control" id="studentGPA" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fillEditModal(id, name, email, interest, gpa) {
            document.getElementById('modalTitle').innerText = "Edit Student Details";
            document.getElementById('studentId').value = id;
            document.getElementById('studentName').value = name;
            document.getElementById('studentEmail').value = email;
            document.getElementById('studentInterest').value = interest;
            document.getElementById('studentGPA').value = gpa;

            var myModal = new bootstrap.Modal(document.getElementById('studentModal'));
            myModal.show();
        }
    </script>
}