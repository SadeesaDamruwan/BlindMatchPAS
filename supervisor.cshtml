@page
@model BlindMatchPAS.Pages.SupervisorsModel
@{
    ViewData["Title"] = "Supervisor Faculty";
}

<style>
    .card-box {
        background: white;
        border-radius: 15px;
        padding: 30px;
        border: 1px solid #eef2f6;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .sup-card {
        border-radius: 12px;
        border: 1px solid #f1f4f8 !important;
        transition: all 0.3s ease;
        background: #fff;
    }

        .sup-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
        }

    .expertise-pill {
        background: #f0f7ff;
        color: #0061f2;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        padding: 5px 12px;
        border-radius: 6px;
        border: 1px solid #ddecff;
    }

    .progress {
        height: 8px;
        border-radius: 10px;
        background-color: #f0f2f5;
    }

    .btn-primary-custom {
        background: #2b3674;
        color: white;
        border: none;
        border-radius: 10px;
        transition: 0.2s;
    }

        .btn-primary-custom:hover {
            background: #1b2559;
            color: white;
        }
</style>

<div class="container-fluid p-4">
    <div class="card-box">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h3 class="fw-bold text-dark m-0">🎓 Supervisor Faculty</h3>
                <p class="text-muted small">Manage faculty workload and research expertise</p>
            </div>
            <button class="btn btn-primary-custom px-4 py-2" data-bs-toggle="modal" data-bs-target="#addSupModal">
                + Assign New Supervisor
            </button>
        </div>

        <div class="row">
            @if (Model.SupervisorList != null && Model.SupervisorList.Any())
            {
                @foreach (var sup in Model.SupervisorList)
                {
                    var percentage = (sup.MaxCapacity > 0) ? (sup.CurrentCount * 100) / sup.MaxCapacity : 0;
                    var colorClass = percentage >= 100 ? "bg-danger" : (percentage >= 80 ? "bg-warning" : "bg-success");

                    <div class="col-xl-4 col-md-6 mb-4">
                        <div class="card sup-card p-4 h-100 border-0 shadow-sm">
                            <h5 class="fw-bold text-dark mb-1">@sup.Name</h5>
                            <p class="text-muted small mb-4">@sup.Department</p>

                            <div class="mb-4">
                                <label class="text-dark small fw-bold d-block mb-2">Expertise:</label>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var exp in sup.Expertise)
                                    {
                                        <span class="expertise-pill">@exp</span>
                                    }
                                </div>
                            </div>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-bold">Workload</span>
                                    <span class="small text-muted">@sup.CurrentCount / @sup.MaxCapacity</span>
                                </div>
                                <div class="progress mb-4">
                                    <div class="progress-bar @colorClass" role="progressbar" style="width: @percentage%"></div>
                                </div>

                                <a asp-page="/SupervisorProfile" asp-route-id="@sup.Id" class="btn btn-outline-dark w-100 fw-bold py-2" style="border-radius: 8px; font-size: 0.85rem;">
                                    View Profile
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No supervisors found in the system.</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="addSupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold">Assign New Supervisor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddSupervisor">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Full Name</label>
                        <input type="text" asp-for="NewSupervisor.Name" class="form-control" placeholder="e.g. Dr. John Doe" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Department</label>
                        <select asp-for="NewSupervisor.Department" class="form-select">
                            <option value="Faculty of Computing">Faculty of Computing</option>
                            <option value="Software Engineering">Software Engineering</option>
                            <option value="Information Systems">Information Systems</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Maximum Capacity</label>
                        <input type="number" asp-for="NewSupervisor.MaxCapacity" class="form-control" value="5">
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary-custom px-4">Save Supervisor</button>
                </div>
            </form>
        </div>
    </div>
</div>