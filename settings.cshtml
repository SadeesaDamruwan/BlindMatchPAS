@page
@model SettingsModel
@{
    Layout = null; // Forces full-screen view
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NSBM | System Settings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* --- DARK MODE ENGINE --- */
        :root {
            --bg-body: #f4f7fe;
            --bg-card: #ffffff;
            --text-main: #2b3674;
            --text-muted: #707eae;
            --border-color: #e9ecef;
            --input-bg: #ffffff;
            --accent: #4318FF;
        }

        [data-theme="dark"] {
            --bg-body: #0b1437;
            --bg-card: #111c44;
            --text-main: #ffffff;
            --text-muted: #a3adcc;
            --border-color: #222e5e;
            --input-bg: #1b254b;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: 'Segoe UI', sans-serif;
            transition: background 0.3s ease;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .settings-container {
            width: 100%;
            max-width: 1100px;
            padding: 20px;
        }

        .card-settings {
            background: var(--bg-card);
            border-radius: 20px;
            border: none;
            padding: 40px;
            box-shadow: 0px 18px 40px rgba(112, 144, 176, 0.12);
        }

        /* --- TABS & UI --- */
        .nav-tabs {
            border-bottom: 1px solid var(--border-color);
        }

        .nav-link {
            color: var(--text-muted);
            border: none !important;
            font-weight: 600;
        }

            .nav-link.active {
                color: var(--text-main) !important;
                border-bottom: 4px solid var(--accent) !important;
                background: none !important;
            }

        .form-control {
            background-color: var(--input-bg);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            border-radius: 12px;
            padding: 12px;
        }

            .form-control:focus {
                background-color: var(--input-bg);
                color: var(--text-main);
                border-color: var(--accent);
                box-shadow: none;
            }

        .form-switch .form-check-input {
            width: 3.5em;
            height: 1.8em;
            cursor: pointer;
        }

        .btn-primary-custom {
            background-color: var(--accent);
            border: none;
            border-radius: 12px;
            padding: 12px 30px;
            font-weight: 600;
        }
    </style>
</head>
<body data-theme="light">

    <div class="settings-container">
        <div class="card-settings">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold">⚙️ System Configuration</h3>
                <div class="form-check form-switch d-flex align-items-center">
                    <input class="form-check-input" type="checkbox" id="darkModeToggle">
                    <label class="ms-2 fw-bold small" for="darkModeToggle">DARK MODE</label>
                </div>
            </div>

            <ul class="nav nav-tabs mb-4" id="settingsTab" role="tablist">
                <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#general">General</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#security">Security</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#notifications">Notifications</a></li>
            </ul>

            <form method="post">
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="general">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">System Name</label>
                                <input type="text" asp-for="SystemName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Admin Email</label>
                                <input type="email" asp-for="AdminEmail" class="form-control" />
                            </div>
                            <div class="col-12 mt-4">
                                <div class="d-flex justify-content-between align-items-center p-3 border rounded-4" style="border-color: var(--border-color) !important;">
                                    <div>
                                        <h6 class="fw-bold mb-0">Maintenance Mode</h6>
                                        <small class="text-muted">Restrict access to everyone except administrators.</small>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" asp-for="IsMaintenanceMode">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="security">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Session Timeout (Minutes)</label>
                            <input type="number" asp-for="SessionTimeout" class="form-control" />
                        </div>
                        <div class="form-check form-switch mt-4">
                            <input class="form-check-input" type="checkbox" asp-for="Enable2FA">
                            <label class="ms-2 fw-bold">Enable Two-Factor Authentication (2FA)</label>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="notifications">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="EmailOnMatch">
                            <label class="form-check-label ms-2">Receive email alerts on new matches</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="WeeklyReports">
                            <label class="form-check-label ms-2">Send weekly system health summary</label>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top d-flex">
                    <button type="submit" class="btn btn-primary btn-primary-custom text-white">Save All Changes</button>
                    <button type="submit" asp-page-handler="Reset" class="btn btn-link text-danger text-decoration-none fw-bold ms-auto">Reset to Defaults</button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Theme Switcher Logic
        const toggle = document.getElementById('darkModeToggle');
        const body = document.body;

        // Load saved preference
        if (localStorage.getItem('theme') === 'dark') {
            body.setAttribute('data-theme', 'dark');
            toggle.checked = true;
        }

        toggle.addEventListener('change', () => {
            if (toggle.checked) {
                body.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            } else {
                body.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
            }
        });
    </script>
</body>
</html>